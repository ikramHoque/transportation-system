# Copy to .env and adjust before running `docker compose up`.

POSTGRES_USER=bts
POSTGRES_PASSWORD=change-me
POSTGRES_DB=bts

# MUST be a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Port the web app is exposed on (http://localhost:APP_PORT)
APP_PORT=8080

# Allowed browser origin(s) for the API (comma separated)
CORS_ORIGIN=http://localhost:8080
