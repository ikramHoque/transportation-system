# Copy to .env and adjust before running `docker compose up`.

POSTGRES_USER=bts
POSTGRES_PASSWORD=change-me
POSTGRES_DB=bts

# MUST be a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Port the web app is exposed on (http://localhost:APP_PORT)
APP_PORT=8080

# Allowed browser origin(s) for the API (comma separated).
# In production (see docker-compose.prod.yml) set this to https://<DOMAIN>.
CORS_ORIGIN=http://localhost:8080

# --- Only needed for production deployment (docker-compose.prod.yml) ---

# Domain name pointed at this VM's public IP. Required for Let's Encrypt --
# it cannot issue a certificate for a bare IP address.
DOMAIN=

# Email Let's Encrypt uses for expiry notices / account recovery.
LETSENCRYPT_EMAIL=
